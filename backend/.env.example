MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/SPVB-CHAT
JWT_SECRET=your-long-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-admin-password-plain-text

# Cloudinary (for media uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# VAPID keys for push notifications — 100% FREE, generate once with:
#
#   python -c "
#   from cryptography.hazmat.primitives.asymmetric import ec
#   from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat, PrivateFormat, NoEncryption
#   import base64
#   priv = ec.generate_private_key(ec.SECP256R1())
#   pub  = priv.public_key()
#   print('VAPID_PUBLIC_KEY='  + base64.urlsafe_b64encode(pub.public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)).rstrip(b'=').decode())
#   print('VAPID_PRIVATE_KEY=' + base64.b64encode(priv.private_bytes(Encoding.DER, PrivateFormat.TraditionalOpenSSL, NoEncryption())).decode())
#   "
VAPID_PUBLIC_KEY=your-generated-vapid-public-key
VAPID_PRIVATE_KEY=your-generated-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com

# Firebase Admin SDK (for FCM push notifications)
# Download serviceAccountKey.json from Firebase Console → Project Settings → Service Accounts
# Then set the path here:
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json
# OR paste the JSON directly (one-liner, base64-encoded):
# FIREBASE_SERVICE_ACCOUNT_JSON=<base64-of-service-account-json>

# Production only
# ALLOWED_ORIGINS=https://your-app.vercel.app
# UPLOADS_DIR=/tmp/uploads

# SMTP (for sending password-reset codes by email)
# Example using Gmail: create an "App Password" at https://myaccount.google.com/apppasswords
# (regular Gmail password will NOT work — 2FA must be enabled on the account)
# If SMTP_SERVER/SMTP_USER/SMTP_PASSWORD are not set, the reset code is returned
# directly in the API response instead (dev/testing fallback only).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=SPVB
